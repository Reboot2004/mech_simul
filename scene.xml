<mujoco model="truck_loading_h1">
  <compiler angle="radian" autolimits="true" meshdir="mujoco_menagerie/unitree_h1/assets"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <include file="mujoco_menagerie/unitree_h1/scene.xml"/>

  <asset>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1="0.6 0.6 0.6" rgb2="0.4 0.4 0.4" width="100" height="100"/>
    <material name="floor_mat" texture="floor_tex" texrepeat="5 5" reflectance="0.2"/>
    <material name="truck_mat" rgba="0.7 0.7 0.3 0.3"/>
    <material name="box_p1" rgba="1.0 0.2 0.2 1"/>
    <material name="box_p2" rgba="1.0 0.6 0.0 1"/>
    <material name="box_p3" rgba="0.2 0.8 0.2 1"/>
    <material name="slot_mat" rgba="0.9 0.9 0.9 0.4"/>
  </asset>

  <worldbody>
    <body name="truck" pos="1.5 0 0">
      <geom name="truck_floor" type="box" size="0.8 0.6 0.02" pos="0 0 0.02" material="truck_mat"/>
      <geom name="truck_left" type="box" size="0.02 0.6 0.3" pos="-0.8 0 0.32" material="truck_mat"/>
      <geom name="truck_right" type="box" size="0.02 0.6 0.3" pos="0.8 0 0.32" material="truck_mat"/>
      <geom name="truck_back" type="box" size="0.8 0.02 0.3" pos="0 -0.6 0.32" material="truck_mat"/>
      <geom name="truck_roof" type="box" size="0.8 0.6 0.01" pos="0 0 0.62" material="truck_mat"/>

      <geom name="slot_b1" type="box" size="0.18 0.18 0.002" pos="-0.45 -0.35 0.042" material="slot_mat"/>
      <geom name="slot_b2" type="box" size="0.18 0.18 0.002" pos="0.0 -0.35 0.042" material="slot_mat"/>
      <geom name="slot_b3" type="box" size="0.18 0.18 0.002" pos="0.45 -0.35 0.042" material="slot_mat"/>
      <geom name="slot_f1" type="box" size="0.18 0.18 0.002" pos="-0.45 0.25 0.042" material="slot_mat"/>
      <geom name="slot_f2" type="box" size="0.18 0.18 0.002" pos="0.0 0.25 0.042" material="slot_mat"/>
      <geom name="slot_f3" type="box" size="0.18 0.18 0.002" pos="0.45 0.25 0.042" material="slot_mat"/>
    </body>

    <body name="box_1" pos="-0.8 0.8 0.1">
      <freejoint/>
      <geom name="box_1_geom" type="box" size="0.12 0.12 0.1" material="box_p1" friction="0.8 0.005 0.0001"/>
      <site name="box_1_site" size="0.01"/>
    </body>

    <body name="box_2" pos="-0.4 0.8 0.1">
      <freejoint/>
      <geom name="box_2_geom" type="box" size="0.12 0.12 0.1" material="box_p2" friction="0.8 0.005 0.0001"/>
      <site name="box_2_site" size="0.01"/>
    </body>

    <body name="box_3" pos="0.0 0.8 0.1">
      <freejoint/>
      <geom name="box_3_geom" type="box" size="0.12 0.12 0.1" material="box_p3" friction="0.8 0.005 0.0001"/>
      <site name="box_3_site" size="0.01"/>
    </body>

    <body name="box_4" pos="0.4 0.8 0.1">
      <freejoint/>
      <geom name="box_4_geom" type="box" size="0.12 0.12 0.1" material="box_p2" friction="0.8 0.005 0.0001"/>
      <site name="box_4_site" size="0.01"/>
    </body>

    <body name="box_5" pos="0.8 0.8 0.1">
      <freejoint/>
      <geom name="box_5_geom" type="box" size="0.12 0.12 0.1" material="box_p3" friction="0.8 0.005 0.0001"/>
      <site name="box_5_site" size="0.01"/>
    </body>

    <camera name="topdown_cam" pos="1.5 0 4.0" euler="0 0 0" fovy="60"/>
    <camera name="side_cam" pos="-2 -2 2" euler="0.6 0 -0.8" fovy="50"/>
    <camera name="front_cam" pos="1.5 -3 1.5" euler="0.4 0 0" fovy="50"/>
  </worldbody>

  <sensor>
    <framepos name="box1_pos" objtype="site" objname="box_1_site"/>
    <framepos name="box2_pos" objtype="site" objname="box_2_site"/>
    <framepos name="box3_pos" objtype="site" objname="box_3_site"/>
    <framepos name="box4_pos" objtype="site" objname="box_4_site"/>
    <framepos name="box5_pos" objtype="site" objname="box_5_site"/>
  </sensor>
</mujoco>
